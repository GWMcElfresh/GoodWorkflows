#!/usr/bin/env bash
# run-compose – wrapper around podman-compose for HPC/SLURM single-node jobs.
#
# Usage:
#   run-compose [OPTIONS]
#
# Options:
#   -f, --file FILE          Path to compose file          (default: compose.yaml)
#   -p, --project-name NAME  Podman-compose project name   (default: basename of workdir)
#   -w, --workdir DIR        Working directory              (default: $PWD)
#   -e, --env-file FILE      Load environment variables from FILE
#   -l, --log-dir DIR        Directory to write log files  (default: <workdir>/logs)
#   -d, --down               Run 'podman-compose down' after exit (cleanup)
#   -n, --dry-run            Print commands without executing
#   -h, --help               Show this help and exit
#
# The script exits with the exit code returned by podman-compose.
# ---------------------------------------------------------------------------- #

set -euo pipefail

# ---------------------------------------------------------------------------- #
# Defaults
# ---------------------------------------------------------------------------- #
COMPOSE_FILE="compose.yaml"
PROJECT_NAME=""
WORKDIR="${PWD}"
ENV_FILE=""
LOG_DIR=""
DO_DOWN=false
DRY_RUN=false

# ---------------------------------------------------------------------------- #
# Logging helpers
# ---------------------------------------------------------------------------- #
log()  { echo "[run-compose] $(date '+%Y-%m-%dT%H:%M:%S') $*" >&2; }
die()  { log "ERROR: $*"; exit 1; }
info() { log "INFO:  $*"; }
warn() { log "WARN:  $*"; }

# ---------------------------------------------------------------------------- #
# Usage
# ---------------------------------------------------------------------------- #
usage() {
cat <<EOF
run-compose – rootless podman-compose launcher for HPC/SLURM

Usage: run-compose [OPTIONS]

Options:
  -f, --file FILE          Compose file to use          (default: compose.yaml)
  -p, --project-name NAME  Project name                 (default: basename of workdir)
  -w, --workdir DIR        Working directory             (default: \$PWD)
  -e, --env-file FILE      Optional .env file to load
  -l, --log-dir DIR        Log directory                 (default: <workdir>/logs)
  -d, --down               Run 'podman-compose down' after workflow exits
  -n, --dry-run            Print commands; do not execute
  -h, --help               Show this help and exit
EOF
}

# ---------------------------------------------------------------------------- #
# Argument parsing
# ---------------------------------------------------------------------------- #
while [[ $# -gt 0 ]]; do
    case "$1" in
        -f|--file)          COMPOSE_FILE="$2"; shift 2 ;;
        -p|--project-name)  PROJECT_NAME="$2"; shift 2 ;;
        -w|--workdir)       WORKDIR="$2";      shift 2 ;;
        -e|--env-file)      ENV_FILE="$2";     shift 2 ;;
        -l|--log-dir)       LOG_DIR="$2";      shift 2 ;;
        -d|--down)          DO_DOWN=true;      shift   ;;
        -n|--dry-run)       DRY_RUN=true;      shift   ;;
        -h|--help)          usage; exit 0 ;;
        --) shift; break ;;
        -*) die "Unknown option: $1" ;;
        *)  break ;;
    esac
done

# ---------------------------------------------------------------------------- #
# Validate workdir
# ---------------------------------------------------------------------------- #
WORKDIR="$(realpath -e "${WORKDIR}")" || die "Workdir does not exist: ${WORKDIR}"
cd "${WORKDIR}"

# Resolve compose file relative to workdir if not absolute
if [[ "${COMPOSE_FILE}" != /* ]]; then
    COMPOSE_FILE="${WORKDIR}/${COMPOSE_FILE}"
fi
[[ -f "${COMPOSE_FILE}" ]] || die "Compose file not found: ${COMPOSE_FILE}"

# Project name defaults to workdir basename
if [[ -z "${PROJECT_NAME}" ]]; then
    PROJECT_NAME="$(basename "${WORKDIR}")"
fi

# Sanitise project name: lowercase first, then strip disallowed characters
# (podman-compose accepts only [a-z0-9_-])
PROJECT_NAME="${PROJECT_NAME,,}"
PROJECT_NAME="${PROJECT_NAME//[^a-z0-9_-]/}"
[[ -n "${PROJECT_NAME}" ]] || PROJECT_NAME="project"

# ---------------------------------------------------------------------------- #
# Log directory
# ---------------------------------------------------------------------------- #
if [[ -z "${LOG_DIR}" ]]; then
    LOG_DIR="${WORKDIR}/logs"
fi
RUN_STAMP="$(date '+%Y%m%dT%H%M%S')"
RUN_LOG_DIR="${LOG_DIR}/${PROJECT_NAME}-${RUN_STAMP}"

if [[ "${DRY_RUN}" == "false" ]]; then
    mkdir -p "${RUN_LOG_DIR}"
fi

COMPOSE_LOG="${RUN_LOG_DIR}/compose.log"

# ---------------------------------------------------------------------------- #
# Runtime directory (rootless Podman requirement)
# ---------------------------------------------------------------------------- #
# Prefer SLURM scratch, then XDG_RUNTIME_DIR, then a tmpdir fallback.
setup_runtime_dir() {
    local rt_dir

    # SLURM scratch is fast local storage on the compute node
    if [[ -n "${SLURM_JOB_ID:-}" && -n "${TMPDIR:-}" ]]; then
        rt_dir="${TMPDIR}/runtime-${UID}"
    elif [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
        rt_dir="${XDG_RUNTIME_DIR}"
    else
        rt_dir="/tmp/runtime-${UID}"
    fi

    mkdir -p "${rt_dir}"
    chmod 0700 "${rt_dir}"
    export XDG_RUNTIME_DIR="${rt_dir}"
    info "XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR}"
}

# ---------------------------------------------------------------------------- #
# TMPDIR / scratch setup
# ---------------------------------------------------------------------------- #
setup_tmpdir() {
    if [[ -n "${SLURM_JOB_ID:-}" && -n "${TMPDIR:-}" ]]; then
        export TMPDIR="${TMPDIR}/podman-${SLURM_JOB_ID}"
        mkdir -p "${TMPDIR}"
        info "TMPDIR=${TMPDIR}"
    fi

    # Redirect inner Podman storage (used by podman-compose service launches)
    # to local scratch so service containers don't hit NFS/overlayfs restrictions.
    # TMPDIR is /tmp inside the container (forced by slurm_run.sh), so these
    # paths are always on local node storage.
    local inner_root="${TMPDIR:-/tmp}/podman-inner"
    export CONTAINERS_GRAPHROOT="${inner_root}/storage"
    export CONTAINERS_RUNROOT="${inner_root}/run"
    mkdir -p "${CONTAINERS_GRAPHROOT}" "${CONTAINERS_RUNROOT}"
    info "CONTAINERS_GRAPHROOT=${CONTAINERS_GRAPHROOT}"
    info "CONTAINERS_RUNROOT=${CONTAINERS_RUNROOT}"
}

# ---------------------------------------------------------------------------- #
# Load .env file if provided
# ---------------------------------------------------------------------------- #
load_env_file() {
    local env_file="$1"

    # Resolve relative path
    if [[ "${env_file}" != /* ]]; then
        env_file="${WORKDIR}/${env_file}"
    fi

    [[ -f "${env_file}" ]] || die ".env file not found: ${env_file}"

    info "Loading environment from ${env_file}"
    set -o allexport
    # shellcheck source=/dev/null
    source "${env_file}"
    set +o allexport
}

# ---------------------------------------------------------------------------- #
# Emit SLURM context info
# ---------------------------------------------------------------------------- #
log_slurm_context() {
    if [[ -n "${SLURM_JOB_ID:-}" ]]; then
        info "SLURM_JOB_ID=${SLURM_JOB_ID}"
        info "SLURM_NODELIST=${SLURM_NODELIST:-unknown}"
        info "SLURM_NTASKS=${SLURM_NTASKS:-unknown}"
        info "SLURM_CPUS_ON_NODE=${SLURM_CPUS_ON_NODE:-unknown}"
        info "SLURM_MEM_PER_NODE=${SLURM_MEM_PER_NODE:-unknown}"
    fi
}

# ---------------------------------------------------------------------------- #
# Run a command (or print it in dry-run mode)
# ---------------------------------------------------------------------------- #
run_cmd() {
    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[dry-run] $*" >&2
    else
        "$@"
    fi
}

# ---------------------------------------------------------------------------- #
# Build podman-compose command
# ---------------------------------------------------------------------------- #
build_compose_cmd() {
    local cmd=(
        podman-compose
        --file    "${COMPOSE_FILE}"
        --project-name "${PROJECT_NAME}"
    )
    echo "${cmd[@]}"
}

# ---------------------------------------------------------------------------- #
# Cleanup on exit
# ---------------------------------------------------------------------------- #
cleanup() {
    local rc=$?

    if [[ "${DO_DOWN}" == "true" ]]; then
        info "Running 'podman-compose down' (cleanup)..."
        run_cmd podman-compose \
            --file          "${COMPOSE_FILE}" \
            --project-name  "${PROJECT_NAME}" \
            down || warn "'podman-compose down' exited non-zero"
    fi

    if [[ "${DRY_RUN}" == "false" ]]; then
        info "Logs written to: ${RUN_LOG_DIR}"
    fi

    exit "${rc}"
}
trap cleanup EXIT

# ---------------------------------------------------------------------------- #
# Main
# ---------------------------------------------------------------------------- #
main() {
    info "Starting run-compose"
    info "  Compose file : ${COMPOSE_FILE}"
    info "  Project name : ${PROJECT_NAME}"
    info "  Workdir      : ${WORKDIR}"
    [[ -n "${ENV_FILE}" ]] && info "  Env file     : ${ENV_FILE}"
    info "  Log dir      : ${RUN_LOG_DIR}"
    info "  Down flag    : ${DO_DOWN}"
    info "  Dry-run      : ${DRY_RUN}"

    log_slurm_context
    setup_runtime_dir
    setup_tmpdir

    [[ -n "${ENV_FILE}" ]] && load_env_file "${ENV_FILE}"

    local compose_cmd
    compose_cmd="$(build_compose_cmd)"

    info "Executing: ${compose_cmd} up --abort-on-container-exit"

    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[dry-run] cd ${WORKDIR}"
        echo "[dry-run] ${compose_cmd} up --abort-on-container-exit"
        return 0
    fi

    # Run podman-compose, capturing output to log AND the terminal (tee).
    # We use a process-substitution tee so the script exits with podman-compose's
    # exit code, not tee's.
    {
        podman-compose \
            --file         "${COMPOSE_FILE}" \
            --project-name "${PROJECT_NAME}" \
            up --abort-on-container-exit
    } 2>&1 | tee "${COMPOSE_LOG}"

    # tee masks the real exit code; capture it from the pipeline
    local pipe_rc="${PIPESTATUS[0]}"
    if [[ "${pipe_rc}" -ne 0 ]]; then
        warn "podman-compose exited with code ${pipe_rc}"
        exit "${pipe_rc}"
    fi

    info "podman-compose completed successfully"
}

main "$@"
