/*
 * nextflow.config – split configuration for reusable workflows and profiles.
 */

includeConfig 'configs/base.config'

profiles {
    standard {
        includeConfig (
            (System.getProperty('os.name') ?: '').toLowerCase().contains('linux') &&
            ((System.getenv('SLURM_JOB_ID') ?: '') ||
             (System.getenv('SLURM_CLUSTER_NAME') ?: '') ||
             (System.getenv('SLURM_CONF') ?: '') ||
             new File('/usr/bin/sbatch').exists() ||
             new File('/bin/sbatch').exists())
            ? 'configs/slurm.config' : 'configs/local.config'
        )
        includeConfig (
            (System.getProperty('os.name') ?: '').toLowerCase().contains('linux') &&
            ((System.getenv('SLURM_JOB_ID') ?: '') ||
             (System.getenv('SLURM_CLUSTER_NAME') ?: '') ||
             (System.getenv('SLURM_CONF') ?: '') ||
             new File('/usr/bin/sbatch').exists() ||
             new File('/bin/sbatch').exists())
            ? 'configs/slurm_singularity.config' : 'configs/local.config'
        )
    }

    auto {
        includeConfig (
            (System.getProperty('os.name') ?: '').toLowerCase().contains('linux') &&
            ((System.getenv('SLURM_JOB_ID') ?: '') ||
             (System.getenv('SLURM_CLUSTER_NAME') ?: '') ||
             (System.getenv('SLURM_CONF') ?: '') ||
             new File('/usr/bin/sbatch').exists() ||
             new File('/bin/sbatch').exists())
            ? 'configs/slurm.config' : 'configs/local.config'
        )
        includeConfig (
            (System.getProperty('os.name') ?: '').toLowerCase().contains('linux') &&
            ((System.getenv('SLURM_JOB_ID') ?: '') ||
             (System.getenv('SLURM_CLUSTER_NAME') ?: '') ||
             (System.getenv('SLURM_CONF') ?: '') ||
             new File('/usr/bin/sbatch').exists() ||
             new File('/bin/sbatch').exists())
            ? 'configs/slurm_singularity.config' : 'configs/local.config'
        )
    }

    slurm {
        includeConfig 'configs/slurm.config'
        includeConfig 'configs/slurm_singularity.config'
    }

    slurm_singularity {
        includeConfig 'configs/slurm.config'
        includeConfig 'configs/slurm_singularity.config'
    }

    local {
        includeConfig 'configs/local.config'
    }

    local_gpu {
        includeConfig 'configs/local-gpu.config'
    }

    test_tcr_mil {
        includeConfig 'configs/base.config'
        includeConfig 'configs/local-gpu.config'

        params {
            test_data_dir = "${projectDir}/test-data"
            tcrClustR_container = 'stub'
            milton_container     = 'stub'
            milton_tcr_container = 'stub'
        }

        podman {
            enabled = false
        }

        singularity {
            enabled = false
        }

        docker {
            enabled = false
        }

        process {
            executor  = 'local'
            cpus      = 2
            memory    = '8.GB'
            time      = '2.h'
            maxForks  = 1
            container = null

            // Reduce mil-ton memory requirements for local testing
            withName: 'QUANTIFY_TCR' {
                memory = '8.GB'
            }
            withName: 'GEX_MERGE_COUNTS' {
                memory = '8.GB'
            }
            withName: 'MERGE_TCR_METADATA' {
                memory = '2.GB'
            }
            withName: 'TRAIN_GEX_MIL' {
                memory = '8.GB'
            }
            withName: 'TRAIN_TCR_MIL' {
                memory = '8.GB'
            }
        }
    }

    test {
        includeConfig 'configs/test.config'
    }
}

timeline { enabled = true; overwrite = true; file = "${projectDir}/logs/nf-timeline.html" }
report   { enabled = true; overwrite = true; file = "${projectDir}/logs/nf-report.html"   }
trace    { enabled = true; overwrite = true; file = "${projectDir}/logs/nf-trace.txt"     }
dag      { enabled = true; overwrite = true; file = "${projectDir}/logs/nf-dag.html"      }
