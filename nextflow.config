/*
 * nextflow.config – split configuration for reusable workflows and profiles.
 */

includeConfig 'configs/base.config'

profiles {
    standard {
        def _onSlurm = (System.getProperty('os.name') ?: '').toLowerCase().contains('linux') &&
            ((System.getenv('SLURM_JOB_ID') ?: '') ||
             (System.getenv('SLURM_CLUSTER_NAME') ?: '') ||
             (System.getenv('SLURM_CONF') ?: '') ||
             new File('/usr/bin/sbatch').exists() ||
             new File('/bin/sbatch').exists())
        includeConfig (_onSlurm ? 'configs/slurm.config'             : 'configs/local.config')
        includeConfig (_onSlurm ? 'configs/slurm_singularity.config' : 'configs/local.config')
    }

    auto {
        def _onSlurm = (System.getProperty('os.name') ?: '').toLowerCase().contains('linux') &&
            ((System.getenv('SLURM_JOB_ID') ?: '') ||
             (System.getenv('SLURM_CLUSTER_NAME') ?: '') ||
             (System.getenv('SLURM_CONF') ?: '') ||
             new File('/usr/bin/sbatch').exists() ||
             new File('/bin/sbatch').exists())
        includeConfig (_onSlurm ? 'configs/slurm.config'             : 'configs/local.config')
        includeConfig (_onSlurm ? 'configs/slurm_singularity.config' : 'configs/local.config')
    }

    slurm {
        includeConfig 'configs/slurm.config'
        includeConfig 'configs/slurm_singularity.config'
    }

    slurm_singularity {
        includeConfig 'configs/slurm.config'
        includeConfig 'configs/slurm_singularity.config'
    }

    local {
        includeConfig 'configs/local.config'
    }

    local_gpu {
        includeConfig 'configs/local-gpu.config'
    }

    test {
        includeConfig 'configs/test.config'
    }
}

timeline { enabled = true; overwrite = true; file = "${projectDir}/logs/nf-timeline.html" }
report   { enabled = true; overwrite = true; file = "${projectDir}/logs/nf-report.html"   }
trace    { enabled = true; overwrite = true; file = "${projectDir}/logs/nf-trace.txt"     }
dag      { enabled = true; overwrite = true; file = "${projectDir}/logs/nf-dag.html"      }
