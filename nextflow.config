/*
 * nextflow.config – Pipeline-wide configuration for SLURM + rootless Podman.
 *
 * Key design decisions encoded here:
 *   • Podman is the container engine (rootless, no daemon).
 *   • Every task redirects Podman's graph/run roots to $TMPDIR on the compute
 *     node to avoid overlayfs failures on NFS/Lustre.
 *   • A shared image-cache directory (NXF_PODMAN_CACHEDIR) can be pointed at
 *     an existing Podman image store on gscratch to avoid re-pulling from GHCR
 *     on every job.  The cache is registered as a read-only additional store in
 *     a per-task storage.conf; image layers are read from gscratch but overlay
 *     mounts still happen in local $TMPDIR to avoid NFS permission errors.
 *   • GPU jobs use --partition=batch --qos=gpu --gres=gpu:1.
 *   • -resume / checkpointing requires the work directory to be on a shared
 *     filesystem.  Set NXF_WORK=/gscratch/.../work before sbatch, or rely on
 *     the ./work default when sbatch is run from a gscratch directory.
 */

nextflowVersion = '>=24.04'

// ---------------------------------------------------------------------------
// Parameters – override with --param_name value or -params-file params.yml
// ---------------------------------------------------------------------------
params {
    input         = 'assets/samplesheet.csv'   // CSV: sample_id,raw_data_path
    outdir        = 'results'
    help          = false
}

// ---------------------------------------------------------------------------
// Work directory (must be on a shared filesystem readable by all nodes).
// Override at any time by exporting NXF_WORK before sbatch.
// ---------------------------------------------------------------------------
workDir = './work'

// ---------------------------------------------------------------------------
// Podman container engine
// ---------------------------------------------------------------------------
podman {
    enabled    = true

    // Flags applied to every `podman run` call:
    //   --userns=keep-id          map the host UID/GID into the container
    //   --group-add keep-groups   preserve supplemental groups (gscratch ACLs)
    //   --security-opt label=disable  relax SELinux labelling on HPC nodes
    //
    // To mount extra data paths (e.g. /gscratch/lab/data) that live outside
    // the Nextflow work directory, export before sbatch:
    //   export NXF_PODMAN_VOLUMES="-v /gscratch/lab/data:/gscratch/lab/data"
    runOptions = "--userns=keep-id --group-add keep-groups --security-opt label=disable ${System.getenv('NXF_PODMAN_VOLUMES') ?: ''}"
}

// ---------------------------------------------------------------------------
// Process defaults and per-label resource allocations
// ---------------------------------------------------------------------------
process {

    // -----------------------------------------------------------------------
    // beforeScript – runs on the compute node before EVERY process.
    //
    //   1. Redirects CONTAINERS_GRAPHROOT / RUNROOT to local $TMPDIR so that
    //      overlay mounts never touch NFS/Lustre (which rejects them).
    //   2. Writes a per-task storage.conf.  When NXF_PODMAN_CACHEDIR is set
    //      and points to an existing Podman image store on gscratch, that store
    //      is registered as a read-only additionalimagestores entry so already-
    //      cached images are served from disk without a registry pull.
    //   3. Sets XDG_RUNTIME_DIR (required for rootless Podman on SLURM nodes).
    //   4. Loads the 'podman' module if the cluster uses Lmod / Env Modules.
    //
    // All exported variables are visible to the `podman run` call that Nextflow
    // issues directly after this script completes (same bash process).
    // -----------------------------------------------------------------------
    beforeScript = '''
        set -euo pipefail

        # --- 1. Redirect Podman storage to local node scratch ----------------
        LOCAL_PODMAN_ROOT="${TMPDIR:-/tmp}/podman-${SLURM_JOB_ID:-$$}"
        export CONTAINERS_GRAPHROOT="${LOCAL_PODMAN_ROOT}/storage"
        export CONTAINERS_RUNROOT="${LOCAL_PODMAN_ROOT}/run"
        mkdir -p "${CONTAINERS_GRAPHROOT}" "${CONTAINERS_RUNROOT}"

        # --- 2. Write storage.conf (optionally wires in shared image cache) --
        export CONTAINERS_STORAGE_CONF="${LOCAL_PODMAN_ROOT}/storage.conf"
        {
            printf '[storage]\n'
            printf 'driver = "overlay"\n'
            printf 'graphRoot = "%s"\n' "${CONTAINERS_GRAPHROOT}"
            printf 'runRoot   = "%s"\n\n' "${CONTAINERS_RUNROOT}"
            printf '[storage.options]\n'
            if [[ -n "${NXF_PODMAN_CACHEDIR:-}" && -d "${NXF_PODMAN_CACHEDIR}" ]]; then
                printf 'additionalimagestores = ["%s"]\n\n' "${NXF_PODMAN_CACHEDIR}"
            fi
            printf '[storage.options.overlay]\n'
            printf 'mount_program = "/usr/bin/fuse-overlayfs"\n'
        } > "${CONTAINERS_STORAGE_CONF}"

        # --- 3. XDG_RUNTIME_DIR – rootless Podman socket ---------------------
        export XDG_RUNTIME_DIR="${TMPDIR:-/tmp}/runtime-${UID}"
        mkdir -p "${XDG_RUNTIME_DIR}"
        chmod 0700 "${XDG_RUNTIME_DIR}"

        # --- 4. Load podman module if Lmod / Environment Modules is present --
        if command -v module &>/dev/null; then
            module load podman 2>/dev/null \
                || echo "Warning: 'module load podman' failed – continuing"
        fi
    '''

    // ---- Sensible global defaults (overridden per label) -------------------
    cpus   = 1
    memory = '8.GB'
    time   = '2.h'

    // -----------------------------------------------------------------------
    // process_ingest – data retrieval via rdiscvr (per sample, CPU-only)
    // -----------------------------------------------------------------------
    withLabel: 'process_ingest' {
        cpus           = 4
        memory         = '32.GB'
        time           = '4.h'
        queue          = 'batch'
        clusterOptions = '--get-user-env'
    }

    // -----------------------------------------------------------------------
    // process_seurat – Seurat object processing via cellmembrane (per sample)
    // -----------------------------------------------------------------------
    withLabel: 'process_seurat' {
        cpus           = 8
        memory         = '64.GB'
        time           = '12.h'
        queue          = 'batch'
        clusterOptions = '--get-user-env'
    }

    // -----------------------------------------------------------------------
    // process_gpu – NMF-VAE minibatch training (single job, all samples)
    //   GPU access: --partition=batch --qos=gpu --gres=gpu:1
    // -----------------------------------------------------------------------
    withLabel: 'process_gpu' {
        cpus           = 4
        memory         = '32.GB'
        time           = '24.h'
        queue          = 'batch'
        clusterOptions = '--get-user-env --gres=gpu:1 --qos=gpu'
    }
}

// ---------------------------------------------------------------------------
// SLURM executor
// ---------------------------------------------------------------------------
executor {
    name            = 'slurm'
    queueSize       = 50           // max simultaneous submitted jobs
    submitRateLimit = '10/1min'    // protect the SLURM scheduler
    pollInterval    = '2 min'      // how often Nextflow checks job status
    exitReadTimeout = '10 min'     // wait for exit-code file to appear
}

// ---------------------------------------------------------------------------
// Run reports (written alongside SLURM logs in logs/)
// ---------------------------------------------------------------------------
timeline { enabled = true; file = 'logs/nf-timeline.html' }
report   { enabled = true; file = 'logs/nf-report.html'   }
trace    { enabled = true; file = 'logs/nf-trace.txt'     }
dag      { enabled = true; file = 'logs/nf-dag.html'      }
