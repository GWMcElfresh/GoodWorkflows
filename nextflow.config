/*
 * nextflow.config – split configuration for reusable workflows and profiles.
 */

includeConfig 'configs/base.config'

profiles {
    slurm {
        includeConfig 'configs/slurm.config'
    }

    local {
        includeConfig 'configs/local.config'
    }

    test {
        includeConfig 'configs/test.config'
    }
}

timeline { enabled = true; file = "${projectDir}/logs/nf-timeline.html" }
report   { enabled = true; file = "${projectDir}/logs/nf-report.html"   }
trace    { enabled = true; file = "${projectDir}/logs/nf-trace.txt"     }
dag      { enabled = true; file = "${projectDir}/logs/nf-dag.html"      }
