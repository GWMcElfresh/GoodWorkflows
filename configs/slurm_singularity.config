// SIF files land in NXF_SINGULARITY_CACHEDIR (set by slurm_nextflow.sh / pre-pull job).
// Falls back to ${projectDir}/apptainer-sif so a direct `nextflow run -profile slurm_singularity`
// still works without any extra env setup.

podman {
    enabled = false
}

singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = (System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "${projectDir}/apptainer-sif")
}

params {
    // ESM-2 model selection: A100 cluster uses 650M model (1024-dim embeddings).
    // Switch to esm2_t36_3B_UR50D (3B params) if higher accuracy needed.
    esm2_model_name    = 'facebook/esm2_t33_650M_UR50D'
    tcr_embedding_dim  = 1024   // 1024 for 650M model, 320 for 8M model

    // ESM-2 model for make_tcr_vector_database
    // Use the smallest workable model for CI/dev; use the large model on HPC.
    tcr_vectordb_esm2_model_name = 'facebook/esm2_t48_15B_UR50D'
    tcr_vectordb_max_length      = 128
    // 15B is memory-hungry: default to a small batch size on HPC.
    tcr_vectordb_batch_size      = 1
    tcr_vectordb_knn_k           = 10
    tcr_vectordb_hf_cache_dir    = '/scratch/hf_cache/tcr_vectordb'

    // TDC cache directory — bind-mount to avoid re-downloading across jobs
    tdc_cache_dir      = '/scratch/tdc_cache'
    epitope_fasta      = "${projectDir}/epitopes.fa"
    binding_model_path = "${projectDir}/tcr_epitope_models"
}

process {
    beforeScript = "source '${projectDir}/configs/slurm.apptainer-before.sh'"
    afterScript  = "source '${projectDir}/configs/slurm.apptainer-after.sh'"

    withLabel: 'process_ingest_labkey' {
        containerOptions = "--bind ${((System.getenv('HOME') ?: System.getProperty('user.home')) ?: '')}/.netrc:${((System.getenv('HOME') ?: System.getProperty('user.home')) ?: '')}/.netrc:ro"
    }

    withLabel: 'process_ingest_url' {
        // No .netrc bind mount needed — URL-based ingest doesn't use LabKey auth
    }

    withLabel: 'process_ingest_file' {
        // No .netrc bind mount needed — local-file ingest doesn't need auth
    }

    withLabel: 'process_nmf_vae' {
        // NMF-VAE ARCHS4 cache: bind mount so the 6 GB correlation pickle
        // is shared across runs without re-downloading.
        containerOptions = "--bind ${params.nmf_vae_archs4_cache}:${params.nmf_vae_archs4_cache}:rw"
    }
}
