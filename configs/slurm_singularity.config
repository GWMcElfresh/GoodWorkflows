def netrcHostPath = ((System.getenv('HOME') ?: System.getProperty('user.home')) ?: '') + '/.netrc'
def singularityCacheDir = (System.getenv('NXF_SINGULARITY_CACHEDIR') ?: (System.getenv('NXF_WORK') ?: "${projectDir}/work") + '/.singularity-cache')

podman {
    enabled = false
}

singularity {
    enabled = true
    autoMounts = true
    cacheDir = singularityCacheDir
}

process {
    beforeScript = '''
set -euo pipefail

if command -v module &>/dev/null; then
    module load apptainer 2>/dev/null || module load singularity 2>/dev/null || true
fi
'''

    afterScript = 'true'

    withLabel: 'process_ingest' {
        containerOptions = "--bind ${netrcHostPath}:${netrcHostPath}:ro"
    }
}