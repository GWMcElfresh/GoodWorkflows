def netrcHostPath = ((System.getenv('HOME') ?: System.getProperty('user.home')) ?: '') + '/.netrc'
// SIF files land in NXF_SINGULARITY_CACHEDIR (set by slurm_nextflow.sh / pre-pull job).
// Falls back to ${projectDir}/apptainer-sif so a direct `nextflow run -profile slurm_singularity`
// still works without any extra env setup.
def singularityCacheDir = (System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "${projectDir}/apptainer-sif")

podman {
    enabled = false
}

singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = singularityCacheDir
}

process {
    beforeScript = "source '${projectDir}/configs/slurm.apptainer-before.sh'"
    afterScript  = "source '${projectDir}/configs/slurm.apptainer-after.sh'"

    withLabel: 'process_ingest_labkey' {
        containerOptions = "--bind ${netrcHostPath}:${netrcHostPath}:ro"
    }

    withLabel: 'process_ingest_url' {
        // No .netrc bind mount needed — URL-based ingest doesn't use LabKey auth
    }

    withLabel: 'process_ingest_file' {
        // No .netrc bind mount needed — local-file ingest doesn't use LabKey auth
    }
}
