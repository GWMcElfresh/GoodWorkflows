def netrcHostPath = ((System.getenv('HOME') ?: System.getProperty('user.home')) ?: '') + '/.netrc'

podman {
    enabled = true
    runOptions = "--entrypoint '' --userns=keep-id --group-add keep-groups --security-opt label=disable ${System.getenv('NXF_PODMAN_VOLUMES') ?: ''}"
}

process {
    beforeScript = '''
        set -euo pipefail

        # Prefer an explicit scratch path for podman layer unpacking. This avoids
        # quota failures when /tmp or home-backed paths are too small.
        PODMAN_TMP_BASE="${NXF_PODMAN_TMPDIR:-${SLURM_TMPDIR:-${TMPDIR:-${PWD}/.podman-tmp}}}"
        mkdir -p "${PODMAN_TMP_BASE}"

        LOCAL_PODMAN_ROOT="${PODMAN_TMP_BASE}/podman-${SLURM_JOB_ID:-$$}"
        export CONTAINERS_GRAPHROOT="${LOCAL_PODMAN_ROOT}/storage"
        export CONTAINERS_RUNROOT="${LOCAL_PODMAN_ROOT}/run"
        mkdir -p "${CONTAINERS_GRAPHROOT}" "${CONTAINERS_RUNROOT}"

        export CONTAINERS_STORAGE_CONF="${LOCAL_PODMAN_ROOT}/storage.conf"
        {
            printf '[storage]\n'
            printf 'driver = "overlay"\n'
            printf 'graphRoot = "%s"\n' "${CONTAINERS_GRAPHROOT}"
            printf 'runRoot   = "%s"\n\n' "${CONTAINERS_RUNROOT}"
            printf '[storage.options]\n'
            if [[ -n "${NXF_PODMAN_CACHEDIR:-}" && -d "${NXF_PODMAN_CACHEDIR}" ]]; then
                printf 'additionalimagestores = ["%s"]\n\n' "${NXF_PODMAN_CACHEDIR}"
            fi
            printf '[storage.options.overlay]\n'
            printf 'mount_program = "/usr/bin/fuse-overlayfs"\n'
        } > "${CONTAINERS_STORAGE_CONF}"

        export XDG_RUNTIME_DIR="${PODMAN_TMP_BASE}/runtime-${UID}"
        mkdir -p "${XDG_RUNTIME_DIR}"
        chmod 0700 "${XDG_RUNTIME_DIR}"

        if command -v module &>/dev/null; then
            module load podman 2>/dev/null \
                || echo "Warning: 'module load podman' failed – continuing"
        fi
    '''

    cpus   = 1
    memory = '8.GB'
    time   = '2.h'

    withLabel: 'process_ingest' {
        cpus             = 2
        memory           = '64.GB'
        time             = '8.h'
        queue            = 'batch'
        clusterOptions   = '--get-user-env'
        containerOptions = "--env HOME=/tmp -v ${netrcHostPath}:/tmp/.netrc:ro"
    }

    withLabel: 'process_export' {
        cpus           = 2
        memory         = '64.GB'
        time           = '4.h'
        queue          = 'batch'
        clusterOptions = '--get-user-env'
    }

    withLabel: 'process_harmonize' {
        cpus           = 2
        memory         = '64.GB'
        time           = '8.h'
        queue          = 'batch'
        clusterOptions = '--get-user-env'
    }

    withLabel: 'process_tabulate' {
        cpus           = 2
        memory         = '64.GB'
        time           = '8.h'
        queue          = 'batch'
        clusterOptions = '--get-user-env'
    }

    withLabel: 'process_gpu' {
        cpus           = 4
        memory         = '128.GB'
        time           = '24.h'
        queue          = 'batch'
        clusterOptions = '--get-user-env --gres=gpu:1 --qos=gpu'
    }
}

executor {
    name            = 'slurm'
    queueSize       = 50
    submitRateLimit = '10/1min'
    pollInterval    = '2 min'
    exitReadTimeout = '10 min'
}
