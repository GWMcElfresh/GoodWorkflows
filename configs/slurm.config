def netrcHostPath = ((System.getenv('HOME') ?: System.getProperty('user.home')) ?: '') + '/.netrc'

podman {
    enabled = true
    runOptions = "--entrypoint '' --userns=keep-id --group-add keep-groups --security-opt label=disable ${System.getenv('NXF_PODMAN_VOLUMES') ?: ''}"
}

process {
    beforeScript = new File("${projectDir}/configs/slurm.before.sh").text
    afterScript  = new File("${projectDir}/configs/slurm.after.sh").text

    cpus   = 1
    memory = '8.GB'
    time   = '2.h'
    errorStrategy = {
        if (task.exitStatus in [125, 137] && task.attempt < 5) {
            def baseDelaySec = task.exitStatus == 125 ? (45 * task.attempt) : (30 * task.attempt)
            def jitterSec = new Random().nextInt(30)
            sleep((baseDelaySec + jitterSec) * 1000L)
            return 'retry'
        }
        return 'finish'
    }
    maxRetries = 4

    withLabel: 'process_ingest' {
        cpus             = 2
        memory           = '64.GB'
        time             = '8.h'
        maxForks         = 10
        queue            = 'batch'
        clusterOptions   = '--get-user-env'
        containerOptions = "--env HOME=/tmp -v ${netrcHostPath}:/tmp/.netrc:ro"
    }

    withLabel: 'process_export' {
        cpus           = 2
        memory         = '64.GB'
        time           = '4.h'
        maxForks       = 10
        queue          = 'batch'
        clusterOptions = '--get-user-env'
    }

    withLabel: 'process_harmonize' {
        cpus           = 2
        memory         = '64.GB'
        time           = '8.h'
        maxForks       = 5
        queue          = 'batch'
        clusterOptions = '--get-user-env'
    }

    withLabel: 'process_tabulate' {
        cpus           = 2
        memory         = '64.GB'
        time           = '8.h'
        maxForks       = 10
        queue          = 'batch'
        clusterOptions = '--get-user-env'
    }

    withLabel: 'process_gpu' {
        cpus           = 4
        memory         = '128.GB'
        time           = '24.h'
        maxForks       = 2
        queue          = 'batch'
        clusterOptions = '--get-user-env --gres=gpu:1 --qos=gpu'
    }
}

executor {
    name            = 'slurm'
    queueSize       = 50
    submitRateLimit = '10/1min'
    pollInterval    = '2 min'
    exitReadTimeout = '10 min'
}
