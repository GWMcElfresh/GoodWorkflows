def netrcHostPath = ((System.getenv('HOME') ?: System.getProperty('user.home')) ?: '') + '/.netrc'

podman {
    enabled = true
    runOptions = "--entrypoint '' --userns=keep-id --group-add keep-groups --security-opt label=disable --cgroups=disabled ${System.getenv('NXF_PODMAN_VOLUMES') ?: ''}"
}

process {
    beforeScript = "source '${projectDir}/configs/slurm.before.sh'"
    afterScript  = "source '${projectDir}/configs/slurm.after.sh'"

    cpus   = 1
    memory = '8.GB'
    time   = '2.h'
    errorStrategy = {
        if (task.exitStatus == 1 && task.attempt < 3) {
            def jitterSec = new Random().nextInt(30)
            sleep(((60 * task.attempt) + jitterSec) * 1000L)
            return 'retry'
        }
        if (task.exitStatus in [125, 137] && task.attempt < 5) {
            def baseDelaySec = task.exitStatus == 125 ? (45 * task.attempt) : (30 * task.attempt)
            def jitterSec = new Random().nextInt(30)
            sleep((baseDelaySec + jitterSec) * 1000L)
            return 'retry'
        }
        return 'finish'
    }
    maxRetries = 4

    withLabel: 'process_ingest_labkey' {
        cpus             = 2
        memory           = '64.GB'
        time             = '8.h'
        maxForks         = 10
        queue            = 'batch'
        clusterOptions   = '--get-user-env --gres=disk:1028'
        containerOptions = "--env HOME=/tmp -v ${netrcHostPath}:/tmp/.netrc:ro"
    }

    withLabel: 'process_ingest_url' {
        cpus             = 2
        memory           = '64.GB'
        time             = '8.h'
        maxForks         = 10
        queue            = 'batch'
        clusterOptions   = '--get-user-env --gres=disk:1028'
    }

    withLabel: 'process_ingest_file' {
        cpus             = 2
        memory           = '64.GB'
        time             = '8.h'
        maxForks         = 10
        queue            = 'batch'
        clusterOptions   = '--get-user-env --gres=disk:1028'
    }

    withLabel: 'process_export' {
        cpus           = 2
        memory         = '64.GB'
        time           = '4.h'
        maxForks       = 10
        queue          = 'batch'
        clusterOptions = '--get-user-env --gres=disk:1028'
    }

    withLabel: 'process_harmonize' {
        cpus           = 2
        memory         = '64.GB'
        time           = '8.h'
        maxForks       = 5
        queue          = 'batch'
        clusterOptions = '--get-user-env --gres=disk:1028'
    }

    withLabel: 'process_tabulate' {
        cpus           = 2
        memory         = '64.GB'
        time           = '8.h'
        maxForks       = 10
        queue          = 'batch'
        clusterOptions = '--get-user-env --gres=disk:1028'
    }

    withLabel: 'process_gpu' {
        cpus           = 4
        memory         = '128.GB'
        time           = '24.h'
        maxForks       = 2
        queue          = 'batch'
        clusterOptions = '--get-user-env --gres=disk:1028 --gres=gpu:1 --qos=gpu'
        // Exit 42:  Python-caught CUDA OOM sentinel from integrate.py.
        // Exit 137: OS SIGKILL from the container OOM killer — Python cannot catch
        //           this; there will be no Python traceback in the Nextflow log.
        // Both trigger a retry; integrate.py reduces batch_size by 10 % per attempt
        // (MIN_BATCH_SIZE floor = 64) and dynamically clamps to a VRAM-safe value
        // computed from n_species × n_genes at runtime.
        errorStrategy  = { task.exitStatus in [42, 137] && task.attempt <= 5 ? 'retry' : 'finish' }
        maxRetries     = 5
    }
}

executor {
    name            = 'slurm'
    queueSize       = 50
    submitRateLimit = '10/1min'
    pollInterval    = '2 min'
    exitReadTimeout = '10 min'
}
