/*
 * local-gpu.config — Local execution with NVIDIA GPU passthrough via Podman.
 *
 * Intended for developer workstations with an NVIDIA GPU (8-12 GB VRAM, 32 GB RAM).
 * maxForks=1 ensures only one process runs at a time so memory is never split.
 * The user is responsible for supplying datasets that fit within available VRAM.
 *
 * --privileged is required for rootless Podman GPU passthrough on Fedora-based
 * distributions (Bazzite, Fedora Silverblue, etc.) where SELinux + CDI interaction
 * prevents GPU access without the privileged flag.
 */
podman {
    enabled = true
    runOptions = "--entrypoint '' --platform linux/amd64 --gpus all --privileged ${System.getenv('NXF_DOCKER_VOLUMES') ?: ''}"
}

params {
    local_gpu = true
    // Modest NMF-VAE params for local GPU (8-12 GB VRAM, 32 GB RAM)
    nmf_vae_latent_dim     = 20
    nmf_vae_epochs         = 100
    nmf_vae_batch_size     = 256
}

process {
    executor  = 'local'
    cpus      = 4
    memory    = '16.GB'
    time      = '24.h'
    maxForks  = 1

    withLabel: 'process_ingest_labkey' {
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
        maxRetries = 2
        memory = { 4.GB * task.attempt }
        cpus   = 2
        maxForks = 1
        containerOptions = "-v ${System.getProperty('user.home')}/.netrc:/root/.netrc:ro"
    }

    withLabel: 'process_ingest_url' {
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
        maxRetries = 2
        memory = { 4.GB * task.attempt }
        cpus   = 2
        maxForks = 1
    }

    withLabel: 'process_ingest_file' {
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
        maxRetries = 2
        memory = { 4.GB * task.attempt }
        cpus   = 2
        maxForks = 1
    }

    withLabel: 'process_export' {
        memory   = '4.GB'
        cpus     = 2
        maxForks = 1
    }

    withLabel: 'process_harmonize' {
        memory   = '8.GB'
        cpus     = 2
        maxForks = 1
    }

    withLabel: 'process_tabulate' {
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
        maxRetries = 2
        memory = { 4.GB * task.attempt }
        cpus   = 2
        maxForks = 1
    }

    withLabel: 'process_gpu' {
        memory   = '16.GB'
        cpus     = 4
        maxForks = 1
        // Exit 42:  Python-caught CUDA OOM sentinel from integrate.py.
        // Exit 137: OS SIGKILL from the container OOM killer — Python cannot catch
        //           this; there will be no Python traceback in the Nextflow log.
        // Both trigger a retry; integrate.py reduces batch_size by 10 % per attempt
        // (MIN_BATCH_SIZE floor = 64) and dynamically clamps to a VRAM-safe value
        // computed from n_species × n_genes at runtime.
        errorStrategy = { task.exitStatus in [42, 137] ? 'retry' : 'finish' }
        maxRetries    = 5
    }

    withLabel: 'process_nmf_vae' {
        // Modest params for local GPU (8-12 GB VRAM, 32 GB RAM)
        memory   = '16.GB'
        cpus     = 4
        maxForks = 1
        containerOptions = "-v ${params.nmf_vae_archs4_cache}:${params.nmf_vae_archs4_cache}:rw"
        errorStrategy = { task.exitStatus in [42, 137] ? 'retry' : 'finish' }
        maxRetries    = 5
    }

    // ── mil-ton process labels ────────────────────────────────────────────
    withLabel: 'process_tcr' {
        memory   = '16.GB'
        cpus     = 4
        maxForks = 1
    }

    withLabel: 'process_small' {
        memory   = '4.GB'
        cpus     = 2
        maxForks = 1
    }

    withLabel: 'medium_job' {
        memory   = '16.GB'
        cpus     = 4
        maxForks = 1
    }

    withLabel: 'gpu_long' {
        memory   = '16.GB'
        cpus     = 4
        maxForks = 1
        errorStrategy = { task.exitStatus in [42, 137] ? 'retry' : 'finish' }
        maxRetries    = 3
    }

    withLabel: 'short_job' {
        memory   = '4.GB'
        cpus     = 2
        maxForks = 1
    }
}

executor {
    name = 'local'
}