podman {
    enabled = false
}

docker {
    enabled = false
}

singularity {
    enabled = false
}

apptainer {
    enabled = false
}

process {
    executor  = 'local'
    cpus      = 1
    memory    = '2.GB'
    time      = '30.min'
    container = null

    withLabel: 'process_nmf_vae' {
        // Stub-run merge doesn't need 16 GB — CI runner has ~15.6 GB free.
        // Cap at 4 GB so the process can start while still detecting real OOM.
        memory   = '4.GB'
        cpus     = 2
        maxForks = 1
    }

    withLabel: 'process_gpu' {
        // integration stubs don't need GPU — use modest CPU/memory for CI
        memory   = '4.GB'
        cpus     = 2
        maxForks = 1
    }

    // Stub-run overrides for new workflows: cap memory so processes can start
    // on the CI runner (~15.6 GB free). Actual runs on slurm_singularity have 1 TB.
    withName: 'QUANTIFY_TCR' {
        memory   = '8.GB'
        cpus     = 2
        maxForks = 1
    }
    withName: 'TRAIN_TCR_MIL' {
        memory   = '8.GB'
        cpus     = 2
        maxForks = 1
    }
    withName: 'EMBED_CLONES' {
        memory   = '8.GB'
        cpus     = 2
        maxForks = 1
    }
    withName: 'PREDICT_BINDING' {
        memory   = '4.GB'
        cpus     = 2
        maxForks = 1
    }
    withName: 'TCR_UMAP' {
        memory   = '4.GB'
        cpus     = 2
        maxForks = 1
    }
    withName: 'JOIN_SEURAT' {
        memory   = '4.GB'
        cpus     = 2
        maxForks = 1
    }
    withName: 'MERGE_TCR_METADATA' {
        memory   = '2.GB'
        cpus     = 1
        maxForks = 1
    }
    withName: 'GEX_MERGE_COUNTS' {
        memory   = '8.GB'
        cpus     = 2
        maxForks = 1
    }
    withName: 'TRAIN_GEX_MIL' {
        memory   = '8.GB'
        cpus     = 2
        maxForks = 1
    }
}

executor {
    name = 'local'
}
