manifest {
    nextflowVersion = '>=24.04'
}

params {
    workflow               = 'integration'
    input                  = "${projectDir}/data/samplesheet.csv"
    outdir                 = "${projectDir}/outputs"
    help                   = false
    labkey_base_url        = ''
    labkey_folder          = ''
    species_order          = 'human,macaque,mouse'
    export_assay           = 'RNA'
    scmodal_container      = 'ghcr.io/gwmcelfresh/scmodal:latest'
    // CI-only flag: bypass the local-executor GPU guard and run SCMODAL as a stub.
    // Intended exclusively for GitHub Actions smoke tests. Enabling this outside
    // GitHub Actions emits a warning; scientific validity of outputs is NOT guaranteed.
    scmodal_use_cpu        = false
    // Set to true by -profile local_gpu to allow GPU workflows on a local machine
    // with an NVIDIA GPU and Podman GPU passthrough (--gpus all).
    local_gpu              = false
    scmodal_latent         = 20
    scmodal_training_steps = 10000
    scmodal_batch_size     = 500
    scmodal_neighbors      = 30
    leiden_resolution      = 0.5
    // NMF-VAE parameters
    nmfvae_container       = 'ghcr.io/gwmcelfresh/nmf-vae:latest'
    nmf_vae_latent_dim     = 50
    nmf_vae_epochs         = 200
    nmf_vae_batch_size     = 512
    nmf_vae_lr             = 1e-3
    nmf_vae_lambda_graph   = 'moderate'
    nmf_vae_archs4_cache   = "${projectDir}/.archs4"
    nmf_vae_archs4_pkl     = "${projectDir}/.archs4/human_correlation_v2.4.pkl"
    nmf_vae_species_id     = 9606
    // Comma-separated id columns carried through to subjectIdTable.csv.
    // cDNA_ID is always included; list any additional subject-level columns here.
    tabulate_id_cols       = 'cDNA_ID,SubjectId,Vaccine,Timepoint,Tissue'
    // Extra cell-type columns to tabulate IN ADDITION TO the standard RIRA columns
    // (RIRA_Immune.cellclass, RIRA_TNK_v2.cellclass, RIRA_Myeloid_v3.cellclass),
    // which are always processed automatically when present in the metadata.
    // Leave empty to use only the standard RIRA columns.
    tabulate_celltype_cols = ''
    // Parent column used to subset child cell-type columns.  Defaults to
    // RIRA_Immune.cellclass when left empty.
    tabulate_parent_col    = ''
    // Comma-separated celltype_col:parentValue pairs that extend or override the
    // built-in hierarchy (TNK_v2->TNK, Myeloid_v3->Myeloid).  Format:
    //   'RIRA_TNK_v2.cellclass:TNK,RIRA_Myeloid_v3.cellclass:Myeloid'
    tabulate_celltype_parent_map = ''
    repo_sync_url          = 'https://github.com/GWMcElfresh/GoodWorkflows.git'
    repo_sync_branch       = 'main'

    // ── mil-ton GEX MIL ─────────────────────────────────────────────────────
    milton_container       = 'ghcr.io/gwmcelfresh/mil-ton:latest'
    scvi_latent           = 50
    scvi_epochs           = 200
    mil_lr                = 1e-3
    mil_epochs            = 100
    mil_heads             = 5
    mil_embed_dim         = 128
    mil_dropout           = 0.2
    mil_train_fraction    = 0.7
    // milton_pretrained_gex  = ''   // path to .pt checkpoint (optional)

    // mil-ton GEX MIL — template variable mappings
    // train_gex_mil.py reads params.milton_*
    milton_donor_col       = 'SubjectId'
    milton_label_col       = 'disease_status'
    milton_cells_per_donor = 2000
    milton_n_latent        = 50
    milton_batch_key       = ''           // empty = no batch correction
    milton_encoder_dims    = '128,64'
    milton_attention_dim   = 64
    milton_epochs          = 100
    milton_seed            = 42
    milton_dropout          = 0.2        // redundant with params.mil_dropout

    // ── mil-ton TCR MIL ──────────────────────────────────────────────────────
    tcrClustR_container   = 'ghcr.io/bimberlabinternal/tcrclustr:latest'
    bert_model            = 'Rostlab/prot_bert'   // 768-dim (prot_bert, NOT prot_bert_bfd)
    tcr_top_n             = 100
    tcr_chain             = 'TRB'
    tcr_region            = 'cdr3'
    milton_tcr_container  = 'ghcr.io/gwmcelfresh/mil-ton:latest'
    tcr_epochs            = 100
    tcr_lr                = 3e-5
    tcr_warmup_steps      = 50
    // bert_pretrained        = ''   // path to .pt checkpoint (optional)

    // tcrClustR params (read by quantify_tcr.R)
    tcrOrganism            = 'human'
    tcrChains              = 'TRA,TRB'
    tcrMinimumCloneSize    = 2
    tcrRunDirichlet        = false
    tcrDirichletMaxSamples = 100
    tcrDirichletIterations = 1000

    // mil-ton TCR MIL — template variable mappings
    // train_tcr_mil.py reads params.tcrMil*
    tcrMilNTcrs            = 100
    tcrMilMaxTcrLen        = 24
    tcrMilBertModel        = 'Rostlab/prot_bert'
    tcrMilBertHidden       = 768          // 768 for prot_bert, 1024 for prot_bert_bfd
    tcrMilNClasses         = 2
    tcrMilNEnsemble        = 5
    tcrMilEpochs           = 100
    tcrMilLR               = 3e-5
    tcrMilWeightDecay      = 1e-3
    tcrMilSeed             = 42
    tcrMilLabelCol         = 'disease_status'

    // ── tcr_epitope: ESM-2 clone embedding + binding prediction ─────────────────
    esm2_model_name         = 'facebook/esm2_t6_8M_UR50D'
    epitope_fasta          = "${projectDir}/epitopes.fa"
    binding_model_path     = "${projectDir}/tcr_epitope_models"
    tcr_umap_resolution    = 1.0
    tcr_embedding_dim      = 320         // fixed for esm2_t6_8M_UR50D
    tdc_cache_dir           = '/tmp/tdc_cache/'
}

// workDir intentionally NOT set here — let run.sh's -work-dir CLI flag control it.
// Setting workDir in config overrides the CLI flag in Nextflow 26.04, which
// breaks per-run work directory isolation in template/gw/run.sh.

// ── mil-ton process resources ──────────────────────────────────────────────
process {
    withName: 'GEX_MERGE_COUNTS' {
        container = { params.milton_container ?: "ghcr.io/gwmcelfresh/mil-ton:latest" }
        cpus      = 8
        memory    = '32 GB'
        time      = '1h'
        label     = 'medium_job'
    }
    withName: 'TRAIN_GEX_MIL' {
        container = { params.milton_container ?: "ghcr.io/gwmcelfresh/mil-ton:latest" }
        cpus      = 16
        memory    = '64 GB'
        time      = '48h'
        label     = 'gpu_long'
    }
    withName: 'QUANTIFY_TCR' {
        container = { params.tcrClustR_container ?: "ghcr.io/bimberlabinternal/tcrclustr:latest" }
        cpus      = 8
        memory    = '32 GB'
        time      = '4h'
        label     = 'medium_job'
    }
    withName: 'MERGE_TCR_METADATA' {
        container = { params.milton_container ?: "ghcr.io/gwmcelfresh/mil-ton:latest" }
        cpus      = 4
        memory    = '8 GB'
        time      = '30m'
        label     = 'short_job'
    }
    withName: 'TRAIN_TCR_MIL' {
        container = { params.milton_tcr_container ?: "ghcr.io/gwmcelfresh/mil-ton:latest" }
        cpus      = 16
        memory    = '64 GB'
        time      = '48h'
        label     = 'gpu_long'
    }
    withName: 'EMBED_CLONES' {
        container = { params.milton_tcr_container ?: "ghcr.io/gwmcelfresh/mil-ton:latest" }
        cpus      = 8
        memory    = '32 GB'
        time      = '4h'
        label     = 'process_gpu'
    }
    withName: 'PREDICT_BINDING' {
        container = { params.milton_tcr_container ?: "ghcr.io/gwmcelfresh/mil-ton:latest" }
        cpus      = 4
        memory    = '8 GB'
        time      = '2h'
        label     = 'process_lowcpu'
    }
    withName: 'TCR_UMAP' {
        container = { params.milton_tcr_container ?: "ghcr.io/gwmcelfresh/mil-ton:latest" }
        cpus      = 4
        memory    = '8 GB'
        time      = '1h'
        label     = 'process_lowcpu'
    }
}
