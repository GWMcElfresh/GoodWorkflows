# ---------------------------------------------------------------------------- #
# .env.example – copy to .env and customise before running
# ---------------------------------------------------------------------------- #

# Log verbosity passed into service containers
LOG_LEVEL=INFO

# Model stage parameters
MODEL_PARAMS=default

# Override the container image used by slurm_run.sh
# IMAGE=ghcr.io/gwmcelfresh/podmanwrapper:latest

# Override the compose file used by run-compose
# COMPOSE_FILE=compose.yaml

# Override the project name
# PROJECT_NAME=myjob

# Extra arguments forwarded to run-compose by slurm_run.sh
# EXTRA_ARGS=--dry-run
